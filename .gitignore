# Go binaries

*.exe
*.exe~
*.dll
*.so
*.dylib

# Build output

bin/
build/
dist/

# Test binaries

*.test

# Coverage / profiling

*.out
coverage.*
*.coverprofile
profile.cov

# Go dependency (commit go.mod and go.sum)

# vendor/

# Go workspace

go.work
go.work.sum

# Environment

.env
.env.*
!.env.example

# Logs

logs/
*.log

# Temporary files

tmp/
temp/

# IDE

.idea/
.vscode/

# OS files

.DS_Store
Thumbs.db

# Generated files

*.cache

# Docker override

docker-compose.override.yml
